{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["vite/client"],
    "paths": {
      "@immersive/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src"]
}
